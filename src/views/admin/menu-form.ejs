<%- include('../partials/header.ejs') %>

    <main id="admin-menu-form">
        <h1>
            <%= title %>
        </h1>
        <a href="/admin/menu">← Back to Menu List</a>

        <% if (error) { %>
            <div class="status-message status-error"><%= error %></div>
        <% } %>

        <% if (errors && errors.length) { %>
            <ul class="error-list">
                <% errors.forEach(item=> { %>
                    <li><%= item %></li>
                    <% }); %>
            </ul>
        <% } %>

        <% const currentItem = Object.keys(formData || {}).length ? { ...(item || {}), ...formData } : (item || {}); %>

        <form method="POST" action="<%= item ? `/admin/menu/edit/${item.id}` : '/admin/menu/add' %>">
            <div class="form-group">
                <label>Name *</label>
                <input type="text" name="name" value="<%= currentItem.name || '' %>" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="4"><%= currentItem.description || '' %></textarea>
            </div>

            <div class="form-group">
                <label>Price *</label>
                <input type="number" step="0.01" name="price" value="<%= currentItem.price || '' %>" required>
            </div>

            <div class="form-group">
                <label>Category *</label>
                <select name="categoryId" required>
                    <% categories.forEach(cat=> { %>
                        <option value="<%= cat.id %>" <%=(currentItem.categoryId == cat.id || currentItem.category_id == cat.id) ? 'selected' : '' %>>
                            <%= cat.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <div class="form-group">
                <label>
                    <input type="checkbox" name="available" <%=(currentItem.available === true || currentItem.available === 'true' || currentItem.available === 'on' || !item) ? 'checked' : '' %>>
                    Available
                </label>
            </div>

            <button type="submit" class="btn">
                <%= item ? 'Update' : 'Add' %> Item
            </button>
        </form>
    </main>