<!DOCTYPE html>
<html>

    <head>
        <title>
            <%= title %>
        </title>
        <style>
            body {
                font-family: Arial;
                max-width: 1200px;
                margin: 0 auto;
                padding: 20px;
            }

            .menu-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                gap: 20px;
            }

            .menu-item {
                border: 1px solid #ddd;
                padding: 15px;
                border-radius: 8px;
            }

            .price {
                font-size: 1.2em;
                color: #e63946;
                font-weight: bold;
            }

            .btn {
                background: #e63946;
                color: white;
                border: none;
                padding: 10px 20px;
                cursor: pointer;
                border-radius: 4px;
                text-decoration: none;
                display: inline-block;
            }

            .btn:hover {
                background: #d32f3d;
            }

            .category-filter {
                margin: 20px 0;
            }

            .category-filter a {
                margin-right: 15px;
                padding: 8px 16px;
                background: #f0f0f0;
                text-decoration: none;
                border-radius: 4px;
            }

            .category-filter a.active {
                background: #e63946;
                color: white;
            }
        </style>
    </head>

    <body>
        <h1>
            <%= title %>
        </h1>
        <a href="/">Home</a> | <a href="/cart">Cart</a>

        <div class="category-filter">
            <a href="/menu" class="<%= !selectedCategory ? 'active' : '' %>">All</a>
            <% categories.forEach(cat=> { %>
                <a href="/menu?category=<%= cat.id %>" class="<%= selectedCategory == cat.id ? 'active' : '' %>">
                    <%= cat.name %>
                </a>
                <% }); %>
        </div>

        <div class="menu-grid">
            <% menuItems.forEach(item=> { %>
                <div class="menu-item">
                    <h3>
                        <%= item.name %>
                    </h3>
                    <p>
                        <%= item.description %>
                    </p>
                    <p class="price">$<%= item.price %>
                    </p>
                    <% if (item.available) { %>
                        <form action="/cart/add" method="POST">
                            <input type="hidden" name="menuItemId" value="<%= item.id %>">
                            <input type="number" name="quantity" value="1" min="1" max="10" style="width: 60px;">
                            <button type="submit" class="btn">Add to Cart</button>
                        </form>
                        <% } else { %>
                            <span>Unavailable</span>
                            <% } %>
                </div>
                <% }); %>
        </div>
    </body>

</html>