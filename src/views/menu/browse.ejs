<%- include('../partials/header.ejs') %>
        <main id="menu">
            <h1>
                <%= title %>
            </h1>
            <!-- <a href="/">Home</a> | <a href="/cart">Cart</a> -->

            <div class="category-filter">
                <a href="/menu" class="<%= !selectedCategory ? 'active' : '' %>">All</a>
                <% categories.forEach(cat=> { %>
                    <a href="/menu?category=<%= cat.id %>" class="<%= selectedCategory == cat.id ? 'active' : '' %>">
                        <%= cat.name %>
                    </a>
                    <% }); %>
            </div>

            <div class="menu-grid">
                <% menuItems.forEach(item=> { %>
                    <div class="menu-item">
                        <% if (item.image_path) { %>
                            <img src="<%= item.image_path %>" alt="<%= item.image_alt || item.name %>" class="menu-item-img">
                        <% } %>
                        <h3>
                            <%= item.name %>
                        </h3>
                        <p class="menu-item-description">
                            <%= item.description %>
                        </p>
                        <p class="price">$<%= item.price %>
                        </p>
                        <div class="menu-item-action">
                            <% if (item.available) { %>
                                <form action="/cart/add" method="POST">
                                    <input type="hidden" name="menuItemId" value="<%= item.id %>">
                                    <input type="number" name="quantity" value="1" min="1" max="10">
                                    <button type="submit" class="btn"><span class="add-btn">+</span></button>
                                </form>
                            <% } else { %>
                                <span>Unavailable</span>
                            <% } %>
                        </div>
                    </div>
                    <% }); %>
            </div>
        </main>
<%- include('../partials/footer.ejs') %>