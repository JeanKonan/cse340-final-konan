<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=shopping_cart" />
    
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <script src="/scripts/header.js" defer></script>
    <%- renderStyles() %>
    <%- renderScripts() %>
    <title><%= title %></title>
</head>
<body>
    <header>
        <div class="header-branding">
            <p>
                Eat healthy, Live well <br>
                Your health, Our priority
            </p>
            <h4 id="logo"><a href="/">Yofe Eats</a></h4>
        </div>

        <button type="button" class="nav-toggle" aria-controls="site-navigation" aria-expanded="false" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <nav id="site-navigation" class="site-nav">
            <a href="/menu" <% if (title === 'Menu') { %>class="active"<% } %>>Menu</a>
            <a href="/contact" <% if (title === 'Contact') { %>class="active"<% } %>>Contact</a>

            <% if (user && user.role === 'admin') { %>
                <a href="/admin/menu" <% if (title === 'Admin Menu Management' || title === 'Add Menu Item' || title === 'Edit Menu Item') { %>class="active"<% } %>>Admin</a>
                <a href="/kitchen" <% if (title === 'Kitchen Dashboard') { %>class="active"<% } %>>Kitchen</a>
                <a href="/account/myorders" <% if (title === 'My orders') { %>class="active"<% } %>>myOrders</a>
                <form method="POST" action="/account/logout">
                    <button type="submit">Logout</button>
                </form>

            <% } else if (user && user.role === 'kitchen') { %>
                <a href="/kitchen" <% if (title === 'Kitchen Dashboard') { %>class="active"<% } %>>Kitchen</a>
                <form method="POST" action="/account/logout">
                    <button type="submit">Logout</button>
                </form>

            <% } else if (user) { %>
                <a href="/account/myorders" <% if (title === 'My orders') { %>class="active"<% } %>>myOrders</a>
                <form method="POST" action="/account/logout">
                    <button type="submit">Logout</button>
                </form>
                
            <% } else { %>
                <a href="/account/login" <% if (title === 'Login') { %>class="active"<% } %>>Login</a>
                <a href="/account/register" <% if (title === 'Register') { %>class="active"<% } %>>Register</a>
            <% } %>
        </nav>
    </header>

    </header>

<% 
    const messages = flash();
    const hasMessages = Object.values(messages).some(arr => arr.length > 0);
%>

<% if (hasMessages) { %>
    <div class="flash-messages">
        <% Object.keys(messages).forEach(type => { %>
            <% messages[type].forEach(message => { %>
                <div class="flash <%= type %>">
                    <%= message %>
                </div>
            <% }); %>
        <% }); %>
    </div>
<% } %>