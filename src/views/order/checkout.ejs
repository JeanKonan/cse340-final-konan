<%- include('../partials/header.ejs') %>

    <main id="checkout">
        <h1>
            <%= title %>
        </h1>
        <a href="/cart" class="btn">←</a>

        <% const currentFormData = formData || {}; %>
        <% const pickupChecked = currentFormData.pickup === true || currentFormData.pickup === 'true' || pickup; %>

        <div class="summary">
            <h3>Order Summary</h3>
            <% cart.forEach(item=> { %>
                <p>
                    <%= item.name %> x <%= item.quantity %> - $<%= (item.price * item.quantity).toFixed(2) %>
                </p>
                <% }); %>
                    <hr>
                    <p>Subtotal: $<span id="subtotal-amount"><%= subtotal %></span>
                    </p>
                    <p>Tax: $<span id="tax-amount"><%= tax %></span>
                    </p>
                    <p>Delivery: $<span id="delivery-fee-amount"><%= deliveryFee %></span>
                    </p>
                    <p><strong>Total: $<span id="total-amount"><%= total %></span></strong></p>
        </div>

        <form action="/order/place" method="POST">
            <h2>Delivery Information</h2>

            <div class="form-group">
                <label>Full Name *</label>
                <input type="text" name="customerName" value="<%= currentFormData.customerName || '' %>" required>
            </div>

            <div class="form-group">
                <label>Email *</label>
                <input type="email" name="customerEmail" value="<%= currentFormData.customerEmail || '' %>" required>
            </div>

            <div class="form-group">
                <label>Phone *</label>
                <input type="tel" name="customerPhone" value="<%= currentFormData.customerPhone || '' %>" required>
            </div>

            <div class="form-group">
                <label for="pickup">Pickup?</label>
                <input type="checkbox" id="pickup" name="pickup" value="true" <%= pickupChecked ? 'checked' : '' %> >
            </div>

            <p id="delivery-note">Delivery selected. Please provide your address.</p>

            <div id="delivery-address-fields">
                <div class="form-group">
                    <label>Street Address *</label>
                    <input type="text" name="street" value="<%= currentFormData.street || '' %>" required>
                </div>

                <div class="form-group">
                    <label>City *</label>
                    <input type="text" name="city" value="<%= currentFormData.city || '' %>" required>
                </div>

                <div class="form-group">
                    <label>State * (2 letters)</label>
                    <input type="text" name="state" maxlength="2" value="<%= currentFormData.state || '' %>" required>
                </div>

                <div class="form-group">
                    <label>ZIP Code *</label>
                    <input type="text" name="zip" pattern="[0-9]{5}" value="<%= currentFormData.zip || '' %>" required>
                </div>
            </div>

            <div class="form-group">
                <label>Special Instructions</label>
                <textarea name="specialInstructions" rows="3"><%= currentFormData.specialInstructions || '' %></textarea>
            </div>

            <button type="submit" class="btn">Place Order</button>
        </form>
    </main>

<%- include('../partials/footer.ejs') %>